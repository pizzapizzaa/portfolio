---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
---

<Layout title="Verity Digital MRV - Digital Solutions">
  <Header basePath="/" />
  
  <main class="pt-24">
    <section class="min-h-screen flex items-center justify-center px-4 py-30" style="background-image: url('/assets/projects/verity-01.avif'); background-size: cover; background-position: center; background-repeat: no-repeat;">
      <div class="absolute inset-0" style="background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.7));"></div>
      <div class="max-w-4xl w-full relative z-10">
        <h1 class="text-[80px] md:text-[120px] leading-none font-heading font-bold text-white mb-8">Verity Digital MRV</h1>
        <p class="text-[20px] leading-relaxed" style="color: rgb(255, 184, 0);">
          Project Case Study Coming Soon
        </p>
      </div>
    </section>
  </main>
</Layout>